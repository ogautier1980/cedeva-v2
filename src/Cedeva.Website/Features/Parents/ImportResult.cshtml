@model Cedeva.Core.Interfaces.ParentImportResult
@{
    ViewData["Title"] = Localizer["Import.ResultTitle"];
}

@await Html.PartialAsync("_AlertMessages")

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-file-import me-2"></i>@Localizer["Import.ResultTitle"]</h2>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>@Localizer["Parents"]
            </a>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <div class="row text-center g-3">
                    <div class="col">
                        <div class="h3 mb-0 text-success">@Model.ParentsCreated</div>
                        <small class="text-muted">@Localizer["Import.ParentsCreated"]</small>
                    </div>
                    <div class="col">
                        <div class="h3 mb-0 text-success">@Model.ChildrenCreated</div>
                        <small class="text-muted">@Localizer["Import.ChildrenCreated"]</small>
                    </div>
                    <div class="col">
                        <div class="h3 mb-0 text-secondary">@Model.ParentsReused</div>
                        <small class="text-muted">@Localizer["Import.ParentsReused"]</small>
                    </div>
                    <div class="col">
                        <div class="h3 mb-0 text-secondary">@Model.ChildrenSkipped</div>
                        <small class="text-muted">@Localizer["Import.ChildrenSkipped"]</small>
                    </div>
                    <div class="col">
                        <div class="h3 mb-0">@Model.RowsProcessed</div>
                        <small class="text-muted">@Localizer["Import.RowsProcessed"]</small>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.HasErrors)
        {
            <div class="card border-warning">
                <div class="card-header bg-warning text-dark">
                    <i class="fas fa-exclamation-triangle me-2"></i>@Localizer["Import.Errors"] (@Model.Errors.Count)
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @foreach (var error in Model.Errors)
                        {
                            <li class="list-group-item small">@error</li>
                        }
                    </ul>
                </div>
            </div>
        }

        <div class="mt-3">
            <a asp-action="Import" class="btn btn-primary">
                <i class="fas fa-file-import me-2"></i>@Localizer["Import.Another"]
            </a>
        </div>
    </div>
</div>
