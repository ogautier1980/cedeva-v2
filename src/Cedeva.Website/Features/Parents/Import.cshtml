@{
    ViewData["Title"] = Localizer["Import.Title"];
}

@await Html.PartialAsync("_AlertMessages")

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-file-import me-2"></i>@Localizer["Import.Title"]</h2>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>@Localizer["Parents"]
            </a>
        </div>

        <div class="card">
            <div class="card-body">
                <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                <p class="text-muted">@Localizer["Import.Help"]</p>

                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>@Localizer["Import.ColumnsHelp"]
                    <code class="d-block mt-2">
                        ParentFirstName;ParentLastName;Email;MobilePhone;ParentNRN;Street;PostalCode;City;ChildFirstName;ChildLastName;ChildBirthDate;ChildNRN
                    </code>
                </div>

                <form asp-action="Import" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="csvFile" class="form-label">@Localizer["Import.File"]</label>
                        <input type="file" name="csvFile" id="csvFile" class="form-control" accept=".csv" required />
                        <small class="form-text text-muted">@Localizer["Import.FileHelp"]</small>
                    </div>
                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-file-import me-2"></i>@Localizer["Import.Submit"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
