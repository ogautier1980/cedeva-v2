@model Cedeva.Website.Features.EmailTemplates.ViewModels.ImportTemplatesViewModel
@{
    ViewData["Title"] = Localizer["EmailTemplate.Import"];
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-file-import me-2"></i>@Localizer["EmailTemplate.Import"]</h5>
            </div>
            <div class="card-body">
                <p class="text-muted">@Localizer["EmailTemplate.ImportHelp"]</p>

                @if (Model.Sources.Any())
                {
                    <form asp-action="Import" method="post">
                        <input type="hidden" asp-for="ActivityId" />
                        <div class="mb-3">
                            <label for="sourceActivityId" class="form-label">@Localizer["EmailTemplate.ImportSource"]</label>
                            <select name="sourceActivityId" id="sourceActivityId" class="form-select" asp-items="Model.Sources"></select>
                        </div>
                        <div class="d-flex justify-content-between mt-3">
                            <a asp-action="Index" asp-route-activityId="@Model.ActivityId" class="btn btn-outline-secondary text-nowrap">
                                <i class="fas fa-arrow-left me-2"></i>@Localizer["Cancel"]
                            </a>
                            <button type="submit" class="btn btn-primary text-nowrap">
                                <i class="fas fa-file-import me-2"></i>@Localizer["EmailTemplate.Import"]
                            </button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="fas fa-folder-open fa-2x text-muted mb-3"></i>
                        <p class="text-muted">@Localizer["EmailTemplate.NoSourceActivities"]</p>
                        <a asp-action="Index" asp-route-activityId="@Model.ActivityId" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>@Localizer["Button.Back"]
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
