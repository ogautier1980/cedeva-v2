@model Cedeva.Website.Features.Import.ViewModels.ImportIndexViewModel
@{
    ViewData["Title"] = Localizer["Import.Title"];
    var selected = Model.Selected;
}

@await Html.PartialAsync("_AlertMessages")

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-7">
        <h2 class="mb-4"><i class="fas fa-file-import me-2"></i>@Localizer["Import.Title"]</h2>

        <div class="card mb-3">
            <div class="card-body">
                <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                <p class="text-muted">@Localizer["Import.GenericHelp"]</p>

                <form asp-action="Index" method="get" class="mb-0">
                    <div class="mb-3">
                        <label for="type" class="form-label">@Localizer["Import.EntityType"]</label>
                        <select name="type" id="type" class="form-select" onchange="this.form.submit()">
                            <option value="">@Localizer["Import.SelectType"]</option>
                            @foreach (var option in Model.Importers)
                            {
                                <option value="@option.Key" selected="@(option.Key == Model.SelectedType)">@option.DisplayName</option>
                            }
                        </select>
                    </div>
                </form>
            </div>
        </div>

        @if (selected != null)
        {
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">@selected.DisplayName</h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>@Localizer["Import.ColumnsHelp"]
                        <code class="d-block mt-2">@selected.ColumnsTemplate</code>
                    </div>

                    <form asp-action="Index" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="type" value="@selected.Key" />

                        @if (Model.IsAdmin && !selected.AdminOnly)
                        {
                            <div class="mb-3">
                                <label for="targetOrganisationId" class="form-label">@Localizer["Import.TargetOrganisation"]</label>
                                <select name="targetOrganisationId" id="targetOrganisationId" class="form-select" asp-items="Model.Organisations" required>
                                    <option value="">@Localizer["Import.SelectOrganisation"]</option>
                                </select>
                                <small class="form-text text-muted">@Localizer["Import.TargetOrganisationHelp"]</small>
                            </div>
                        }

                        <div class="mb-3">
                            <label for="csvFile" class="form-label">@Localizer["Import.File"]</label>
                            <input type="file" name="csvFile" id="csvFile" class="form-control" accept=".csv" required />
                            <small class="form-text text-muted">@Localizer["Import.FileHelp"]</small>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-file-import me-2"></i>@Localizer["Import.Submit"]
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
