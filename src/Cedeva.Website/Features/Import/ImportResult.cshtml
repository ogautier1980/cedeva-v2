@model Cedeva.Core.Interfaces.CsvImportResult
@{
    ViewData["Title"] = Localizer["Import.ResultTitle"];
    var typeName = ViewBag.TypeName as string;
}

@await Html.PartialAsync("_AlertMessages")

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-file-import me-2"></i>@Localizer["Import.ResultTitle"] @(string.IsNullOrEmpty(typeName) ? "" : $"— {typeName}")</h2>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>@Localizer["Import.Title"]
            </a>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <div class="row text-center g-3">
                    <div class="col">
                        <div class="h3 mb-0 text-success">@Model.Created</div>
                        <small class="text-muted">@Localizer["Import.Created"]</small>
                    </div>
                    <div class="col">
                        <div class="h3 mb-0 text-secondary">@Model.Skipped</div>
                        <small class="text-muted">@Localizer["Import.Skipped"]</small>
                    </div>
                    <div class="col">
                        <div class="h3 mb-0">@Model.RowsProcessed</div>
                        <small class="text-muted">@Localizer["Import.RowsProcessed"]</small>
                    </div>
                    @foreach (var extra in Model.Extra)
                    {
                        <div class="col">
                            <div class="h3 mb-0 text-info">@extra.Value</div>
                            <small class="text-muted">@Localizer[extra.Key]</small>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (Model.HasErrors)
        {
            <div class="card border-warning">
                <div class="card-header bg-warning text-dark">
                    <i class="fas fa-exclamation-triangle me-2"></i>@Localizer["Import.Errors"] (@Model.Errors.Count)
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @foreach (var error in Model.Errors)
                        {
                            <li class="list-group-item small">@error</li>
                        }
                    </ul>
                </div>
            </div>
        }

        <div class="mt-3">
            <a asp-action="Index" class="btn btn-primary">
                <i class="fas fa-file-import me-2"></i>@Localizer["Import.Another"]
            </a>
        </div>
    </div>
</div>
