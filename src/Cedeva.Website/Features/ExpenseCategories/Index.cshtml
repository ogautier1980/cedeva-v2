@model List<Cedeva.Core.Entities.ExpenseCategory>
@{
    ViewData["Title"] = Localizer["ExpenseCategory.Title"];
}

@await Html.PartialAsync("_AlertMessages")

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-tags me-2"></i>@Localizer["ExpenseCategory.Title"]</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>@Localizer["ExpenseCategory.AddCategory"]
    </a>
</div>

@if (Model.Any())
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">@Localizer["Field.Name"]</th>
                            <th scope="col" class="text-end">@Localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in Model)
                        {
                            <tr>
                                <td>@category.Name</td>
                                <td class="text-end text-nowrap">
                                    <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-secondary">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    @await Html.PartialAsync("_DeleteButton", new DeleteButtonModel { Id = category.Id, ConfirmMessage = Localizer["ExpenseCategory.ConfirmDelete"].Value })
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", new EmptyStateModel
    {
        Icon = "fa-tags",
        Message = Localizer["ExpenseCategory.NoCategories"].Value,
        CreateUrl = Url.Action("Create"),
        CreateText = Localizer["ExpenseCategory.AddCategory"].Value
    })
}
