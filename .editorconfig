root = true

# All files
[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csx}]
indent_size = 4

[*.{csproj,props,targets,xml,config,resx}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.{js,css,cshtml,html}]
indent_size = 4

# ---- C# code style (guidance for the IDE; not enforced at build time) ----
[*.cs]
# Usings
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace:suggestion

# Prefer modern C#
csharp_style_namespace_declarations = file_scoped:suggestion
csharp_prefer_braces = true:silent
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion
dotnet_style_null_propagation = true:suggestion
dotnet_style_coalesce_expression = true:suggestion

# this. qualification — not required (matches existing code style)
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion

# Naming: private fields use _camelCase (per project conventions)
dotnet_naming_rule.private_fields_underscore.severity = suggestion
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_prefixed
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_prefixed.required_prefix = _
dotnet_naming_style.underscore_prefixed.capitalization = camel_case

# Naming: types & members use PascalCase
dotnet_naming_rule.types_pascal.severity = suggestion
dotnet_naming_rule.types_pascal.symbols = types_and_members
dotnet_naming_rule.types_pascal.style = pascal_case
dotnet_naming_symbols.types_and_members.applicable_kinds = class,struct,interface,enum,property,method,event
dotnet_naming_style.pascal_case.capitalization = pascal_case

# ---- Analyzer triage ----

# EF Core migrations are generated code — exclude them from analyzers.
[**/Migrations/*.cs]
generated_code = true

[*.cs]
# CA1873: logging-argument evaluation cost. No auto-fix; the IsEnabled guard hurts
# readability across ~100 call sites. Keep as IDE guidance, not a build warning.
dotnet_diagnostic.CA1873.severity = suggestion
# CA1859: "use concrete type for performance" — micro-optimisation, IDE guidance only.
dotnet_diagnostic.CA1859.severity = suggestion
# CA1860 (Any() vs Count), CA1822 (mark static), CA1861 (constant array -> static readonly),
# CA1846 (AsSpan vs Substring): stylistic / micro-perf, high volume. Keep as IDE guidance.
dotnet_diagnostic.CA1860.severity = suggestion
dotnet_diagnostic.CA1822.severity = suggestion
dotnet_diagnostic.CA1861.severity = suggestion
dotnet_diagnostic.CA1846.severity = suggestion
